# Text
STOPWORDS = {
    "i", "me", "my", "we", "the", "a", "an", "is", "are", "was", "be",
    "do", "does", "to", "of", "in", "on", "at", "for", "with", "and",
    "or", "not", "what", "how", "when", "where", "can", "will", "please",
    "tell", "give", "need", "want", "know", "about", "get", "have", "has"
}

def tokenize(text: str) -> list:
    tokens = re.findall(r'\b[a-z]{2,}\b', text.lower())
    return [t for t in tokens if t not in STOPWORDS]

# TF-IDF
class TFIDF:
    def __init__(self, documents: list):
        self.docs = documents
        self.tokenized_docs = [tokenize(d["question"] + " " + d["answer"]) for d in documents]
        self.N = len(documents)
        self.idf = self._compute_idf()

    def _compute_idf(self) -> dict:
        df = Counter()
        for tokens in self.tokenized_docs:
            for word in set(tokens):
                df[word] += 1
        return {word: math.log((self.N + 1) / (count + 1)) + 1
                for word, count in df.items()}

    def _tf(self, tokens: list) -> dict:
        count = Counter(tokens)
        total = len(tokens) if tokens else 1
        return {word: freq / total for word, freq in count.items()}

    def _tfidf_vector(self, tokens: list) -> dict:
        tf = self._tf(tokens)
        return {word: tf[word] * self.idf.get(word, 0) for word in tf}

    def _cosine_similarity(self, vec1: dict, vec2: dict) -> float:
        common = set(vec1) & set(vec2)
        dot = sum(vec1[w] * vec2[w] for w in common)
        mag1 = math.sqrt(sum(v ** 2 for v in vec1.values()))
        mag2 = math.sqrt(sum(v ** 2 for v in vec2.values()))
        if mag1 == 0 or mag2 == 0:
            return 0.0
        return dot / (mag1 * mag2)

    def search(self, query: str, top_k: int = 3) -> list:
        query_tokens = tokenize(query)
        query_vec = self._tfidf_vector(query_tokens)

        scores = []
        for i, tokens in enumerate(self.tokenized_docs):
            doc_vec = self._tfidf_vector(tokens)
            sim = self._cosine_similarity(query_vec, doc_vec)
            scores.append((i, sim))

        scores.sort(key=lambda x: x[1], reverse=True)
        results = []
        for idx, score in scores[:top_k]:
            if score > 0:
                results.append({
                    "rank": len(results) + 1,
                    "faq_id": self.docs[idx]["id"],
                    "question": self.docs[idx]["question"],
                    "answer": self.docs[idx]["answer"],
                    "score": round(score, 4)
                })
        return results

# Display Top-3 Results
def display_results(results: list, query: str):
    print(f"\n Query: \"{query}\"")
    if not results:
        print(" No relevant answers found. Try rephrasing your question.")
        return

    print(f" Top {len(results)} Matching Answer(s):\n")
    bar_chars = 20

    for r in results:
        # Visual similarity bar
        filled = int(r['score'] * bar_chars / max(results[0]['score'], 0.001))
        bar = "" * filled + "" * (bar_chars - filled)

        print(f"  {'🥇' if r['rank']==1 else '🥈' if r['rank']==2 else '🥉'} Rank {r['rank']}  |  Score: {r['score']:.4f}  [{bar}]")
        print(f"   {r['question']}")
        print(f"   {r['answer']}")
        print()

# Main Chatbot
def run_chatbot():

    engine = TFIDF(FAQ_DATA)
    print(f"\n TF-IDF index built for {len(FAQ_DATA)} FAQ entries.\n")

    while True:
        query = input(" You: ").strip()
        if not query:
            continue
        if query.lower() in ["quit", "exit"]:
            print(" Bot: Goodbye! ")
            break

        results = engine.search(query, top_k=3)
        display_results(results, query)

if __name__ == "__main__":
    run_chatbot()
