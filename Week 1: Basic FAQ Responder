import re

FAQ_DB = {
    "admission": {
        "patterns": ["admission", "apply", "application", "enroll", "join", "eligibility"],
        "answer": "Admissions open every June. You need 60%+ in 12th grade. Apply at sitnagpur.edu.in",
        "followups": ["What are the fees?", "What documents are needed?", "When does college start?"]
    },
    "fees": {
        "patterns": ["fees", "fee", "cost", "charges", "tuition", "payment"],
        "answer": "Annual tuition is ₹85,000. Hostel is ₹40,000/year.",
        "followups": ["How can I pay fees?", "What is the fee deadline?"]
    },
    "timing": {
        "patterns": ["timing", "time", "hours", "schedule", "office hours", "open", "close"],
        "answer": "College hours: Mon–Sat, 9AM–5PM. Office hours: 10AM–4PM. Library open till 7PM.",
        "followups": ["What are exam timings?", "Is the library open on Sundays?", "When are labs available?"]
    },
    "contact": {
        "patterns": ["contact", "phone", "email", "reach", "call", "helpdesk"],
        "answer": " +91 1234567890 |  help@sitnagpur.edu | Office: Room 101, Admin Block.",
        "followups": ["Where is the admin office?", "Who is the principal?", "How do I raise a complaint?"]
    },
    "exam": {
        "patterns": ["exam", "examination", "test", "paper", "result", "marks"],
        "answer": "Mid-sem exams: October & March. End-sem: November & April. Results in 3 weeks after exams.",
        "followups": ["How do I check my results?", "What is the passing criteria?", "When is the exam timetable released?"]
    },
    "hostel": {
        "patterns": ["hostel", "dorm", "accommodation", "stay", "room", "lodge"],
        "answer": "Separate hostels for boys and girls. Capacity: 500 students. Apply by July 31st.",
        "followups": ["What are hostel fees?", "Is food included in hostel?", "Who is the hostel warden?"]
    },
    "documents": {
        "patterns": ["document", "certificate", "marksheet", "id", "proof", "bonafide"],
        "answer": "Required: 10th & 12th marksheets, ID proof, passport photo, caste certificate (if applicable).",
        "followups": ["Where do I submit documents?", "Can I submit digital copies?", "How long does verification take?"]
    }
}

# Pattern Matching
def match_faq(user_input: str):
    user_input_lower = user_input.lower()
    for topic, data in FAQ_DB.items():
        for pattern in data["patterns"]:
            if re.search(r'\b' + pattern + r'\b', user_input_lower):
                return topic, data
    return None, None

# Follow-up Suggestion
def show_followups(followups: list):
    print("\n You might also be interested in knowing:")
    for i, q in enumerate(followups, 1):
        print(f"   [{i}] {q}")
    print("   [0] Ask something else")

# Main Chatbot
def run_chatbot():

    last_followups = []

    while True:
        user_input = input("\n User: ").strip()

        if not user_input:
            continue
        if user_input.lower() in ["quit", "exit", "bye"]:
            print("Thank you")
            break

        # Handle follow-up selection by number
        if user_input.isdigit() and last_followups:
            choice = int(user_input)
            if choice == 0:
                last_followups = []
                print(" Bot: Sure! Ask me anything about the institute.")
                continue
            elif 1 <= choice <= len(last_followups):
                user_input = last_followups[choice - 1]
                print(f" Selected: {user_input}")

        topic, data = match_faq(user_input)

        if data:
            print(f"\n Bot: {data['answer']}")
            last_followups = data["followups"]
            show_followups(last_followups)
        else:
            print("Bot: Sorry, I couldn't find an answer for that.")
            print("   Try asking about: admissions, fees, timings, exams, hostel or contacts.")
            last_followups = []

if __name__ == "__main__":
    run_chatbot()
