# Synonyms from Chat Logs ---
def extract_candidate_words(log: str) -> list:
    stopwords = {
        "i", "me", "my", "the", "a", "an", "is", "are", "was", "be", "do",
        "does", "to", "of", "in", "on", "at", "for", "with", "about", "and",
        "or", "not", "what", "how", "when", "where", "who", "which", "tell",
        "give", "get", "can", "please", "want", "need", "know", "details",
        "any", "all", "this", "that", "it", "if", "us", "we", "you", "your"
    }
    words = re.findall(r'\b[a-z]{3,}\b', log.lower())
    return [w for w in words if w not in stopwords]

def build_synonyms_from_logs(logs: list, verbose: bool = True) -> dict:
    new_synonyms = defaultdict(set)
    word_topic_votes = defaultdict(Counter)  

    for log in logs:
        candidates = extract_candidate_words(log)
        matched_topic = None

        for word in candidates:
            for topic, syns in synonym_dict.items():
                if word in syns:
                    matched_topic = topic
                    break
            if matched_topic:
                break

        if matched_topic:
            for word in candidates:
                if word not in synonym_dict[matched_topic]:
                    word_topic_votes[word][matched_topic] += 1

    for word, votes in word_topic_votes.items():
        best_topic = votes.most_common(1)[0][0]
        new_synonyms[best_topic].add(word)
        synonym_dict[best_topic].add(word)

    if verbose:

        for topic, words in new_synonyms.items():
            if words:
                print(f"   {topic:12s} ← {', '.join(sorted(words))}")
        print()

    return dict(new_synonyms)

# FAQ Matching with Synonym
def match_with_synonyms(query: str) -> tuple:
    query_words = set(re.findall(r'\b[a-z]{3,}\b', query.lower()))
    best_topic = None
    best_overlap = 0

    for topic, syns in synonym_dict.items():
        overlap = len(query_words & syns)
        if overlap > best_overlap:
            best_overlap = overlap
            best_topic = topic

    return best_topic, best_overlap

# Save Updated Synonym
def save_synonyms(filepath="synonym_dict.json"):
    serializable = {k: list(v) for k, v in synonym_dict.items()}
    with open(filepath, "w") as f:
        json.dump(serializable, f, indent=2)
    print(f" Synonym dictionary saved to {filepath}")

